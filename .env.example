# Public API base (no trailing slash). Required for device builds.
EXPO_PUBLIC_API_URL=http://localhost:5000

# Mapbox (maps in the app)
EXPO_PUBLIC_MAPBOX_TOKEN=

# Google Sign-In (OAuth client IDs from Google Cloud Console)
# After changing Android package / iOS bundle ID, register the new IDs in Firebase and Google Cloud.
EXPO_PUBLIC_ANDROID_CLIENT_ID=
EXPO_PUBLIC_IOS_CLIENT_ID=
EXPO_PUBLIC_WEB_CLIENT_ID=

# Firebase Android: add an Android app in Firebase Console with package name com.phuocnguyenkieu.whispery
# and replace google-services.json files under App/ and App/android/app/ with the downloaded config.
