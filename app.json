{
  "expo": {
    "name": "Whispery",
    "slug": "whispery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "whispery",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "jsEngine": "hermes",
      "bundleIdentifier": "com.phuocnguyenkieu.whispery",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.phuocnguyenkieu.whispery"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-audio",
        {
          "microphonePermission": "Cho phép Whispery truy cập microphone để bạn có thể ghi âm tin nhắn thoại."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép Whispery truy cập camera để trải nghiệm tính năng thực tế ảo (AR) tìm kiếm tin nhắn thoại.",
          "microphonePermission": "Cho phép Whispery truy cập microphone trong quá trình sử dụng camera."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cho phép Whispery truy cập thư viện ảnh để bạn có thể chọn và cập nhật ảnh đại diện."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Cho phép Whispery truy cập vị trí ngay cả khi chạy ngầm để thông báo khi bạn ở gần một tin nhắn thoại ẩn.",
          "locationWhenInUsePermission": "Cho phép Whispery truy cập vị trí của bạn để hiển thị các tin nhắn thoại xung quanh trên bản đồ.",
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      "expo-font",
      "./plugins/withModularHeaders",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6e98b491-52e9-4471-9d90-72f2cac09cd5"
      }
    }
  }
}